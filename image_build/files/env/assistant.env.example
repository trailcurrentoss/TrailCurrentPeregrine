# TrailCurrent Peregrine — voice assistant environment config
# This file is the single source of site-specific configuration.
# Edit with: nano ~/assistant.env
# Then restart:  sudo systemctl restart voice-assistant

# ── MQTT broker (uncomment and fill in to enable cloud telemetry) ──
#MQTT_BROKER=192.168.x.x
#MQTT_PORT=8883
#MQTT_USE_TLS=true
#MQTT_CA_CERT=/home/trailcurrent/ca.pem
#MQTT_USERNAME=
#MQTT_PASSWORD=

# ── Audio tuning ──
#
# Wake word detection confidence (0.0–1.0). Higher = fewer false triggers,
# but also harder to activate. Lower values (e.g. 0.5) cause frequent false positives.
WAKE_THRESHOLD=0.90
#
# How many consecutive 80ms frames must score above the threshold before
# the wake word fires. Higher = more reliable, slightly slower response.
WAKE_ACTIVATIONS=3
#
# Minimum audio energy (mean absolute sample value, 0–32768) required
# before a chunk is even passed to the wake word model. Chunks quieter
# than this are silently skipped. Prevents sighs, ambient noise, and
# very quiet sounds from triggering the model at all.
# Raise if you get false triggers on quiet sounds; lower if the wake word
# is missed when speaking softly.
WAKE_MIN_RMS=300
#
# Audio energy level that counts as "speech" during recording (post wake).
# Samples below this are treated as silence. Raise if background noise
# causes recording to never time out; lower if speech is being cut off.
SILENCE_THRESHOLD=500
#
# Seconds of continuous silence after speech before recording stops.
SILENCE_DURATION=1.5
